DATABASE_URL=mysql+pymysql://root:password@localhost:3306/hireai

# Authentication Secret
SECRET_KEY=supersecretjwtkeyforhireaiplatformdevelopment123!
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=120
