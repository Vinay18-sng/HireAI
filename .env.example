# ==========================================
# HireAI Platform Configuration Template
# ==========================================

# 1. Database Configuration
# - For PostgreSQL: postgresql://username:password@host:port/database (automatically supports postgres:// style URLs from Render)
# - For MySQL: mysql+pymysql://username:password@host:port/database
# - For SQLite Fallback: Leave DATABASE_URL blank or set to a sqlite:/// URL (e.g., sqlite:///hireai.db)
DATABASE_URL=

# 2. Authentication and Security
# IMPORTANT: Change SECRET_KEY to a secure random string in production!
SECRET_KEY=supersecretjwtkeyforhireaiplatformdevelopment123!
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=120

# 3. First-Run behavior & Demo Seeding
# Set to 'true' to automatically populate an empty database with sample jobs, candidates, and recruiters.
# Set to 'false' to start with a blank database.
AUTO_SEED=true
